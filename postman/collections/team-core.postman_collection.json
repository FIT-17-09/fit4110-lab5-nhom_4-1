{
	"info": {
		"name": "FIT4110_lab05_team_core",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "00_Health",
			"item": [
				{
					"name": "GET /health - service is alive",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/health",
							"host": ["{{baseUrl}}"],
							"path": ["health"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response has service status\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"status\", \"ok\");",
									"    pm.expect(json).to.have.property(\"db\", \"connected\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "01_Functional",
			"item": [
				{
					"name": "POST /evaluate - happy path creates evaluation",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{authToken}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"source\": \"camera-01\",\n  \"payload\": {\n    \"anomaly\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/evaluate",
							"host": ["{{baseUrl}}"],
							"path": ["evaluate"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"pm.test(\"Evaluation created fields\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"evaluationId\");",
									"    pm.expect(json).to.have.property(\"decision\", \"DENY\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				},
				{
					"name": "GET /evaluations - list records",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{authToken}}", "type": "text" }
						],
						"url": {
							"raw": "{{baseUrl}}/evaluations",
							"host": ["{{baseUrl}}"],
							"path": ["evaluations"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"pm.test(\"Response contains items array\", function () {",
									"    const json = pm.response.json();",
									"    pm.expect(json).to.have.property(\"items\");",
									"    pm.expect(json.items).to.be.an(\"array\");",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "02_Auth",
			"item": [
				{
					"name": "POST /evaluate - missing token is rejected",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"source\": \"camera-01\",\n  \"payload\": {\n    \"anomaly\": true\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/evaluate",
							"host": ["{{baseUrl}}"],
							"path": ["evaluate"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Missing token returns 401\", function () {",
									"    pm.response.to.have.status(401);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "03_Negative",
			"item": [
				{
					"name": "POST /evaluate - missing payload returns error",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{authToken}}", "type": "text" },
							{ "key": "Content-Type", "value": "application/json", "type": "text" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"source\": \"camera-01\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/evaluate",
							"host": ["{{baseUrl}}"],
							"path": ["evaluate"]
						}
					},
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Invalid payload returns client error 400\", function () {",
									"    pm.response.to.have.status(400);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		}
	]
}